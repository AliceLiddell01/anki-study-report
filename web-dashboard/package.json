{
  "name": "anki-study-report-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run typecheck && vite build",
    "build:addon": "pnpm run typecheck && vite build && node scripts/copy-to-addon.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest",
    "test:run": "vitest run",
    "test:python": "cd .. && node scripts/run_python.mjs -m pytest",
    "test:frontend": "pnpm run typecheck && pnpm run test:run",
    "test:build-dashboard": "pnpm run build:addon",
    "test:package": "cd .. && node scripts/run_python.mjs scripts/package_addon.py --check",
    "test:all": "pnpm run test:frontend && pnpm run test:build-dashboard && pnpm run test:python && pnpm run test:package"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.5"
  }
}
