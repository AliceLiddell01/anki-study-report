{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anki-study-report.local/schemas/inspection-profile-v1.schema.json",
  "title": "Anki Study Report Inspection Profile document v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "revision", "profiles"],
  "properties": {
    "schemaVersion": {"const": 1},
    "revision": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "profiles": {
      "type": "array",
      "maxItems": 500,
      "items": {"$ref": "#/$defs/profile"}
    }
  },
  "$defs": {
    "decimalId": {"type": "string", "pattern": "^[1-9][0-9]{0,18}$"},
    "slug": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,39}$"},
    "timestamp": {
      "type": "string",
      "maxLength": 40,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "fieldRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ordinal", "name"],
      "properties": {
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 63},
        "name": {"type": "string", "minLength": 1, "maxLength": 160}
      }
    },
    "fieldMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "fields"],
      "properties": {
        "role": {"$ref": "#/$defs/slug"},
        "fields": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {"$ref": "#/$defs/fieldRef"}
        }
      }
    },
    "checkCommon": {
      "type": "object",
      "properties": {
        "checkId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,79}$"},
        "roles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/slug"}
        },
        "priority": {"enum": ["high", "medium", "low"]}
      }
    },
    "modeCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "kind", "roles", "mode", "priority"],
      "properties": {
        "checkId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,79}$"},
        "kind": {"enum": ["non_empty", "contains_audio", "contains_image"]},
        "roles": {"$ref": "#/$defs/checkCommon/properties/roles"},
        "mode": {"enum": ["any", "all"]},
        "priority": {"enum": ["high", "medium", "low"]}
      }
    },
    "minLengthCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "kind", "roles", "mode", "priority", "minLength"],
      "properties": {
        "checkId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,79}$"},
        "kind": {"const": "min_text_length"},
        "roles": {"$ref": "#/$defs/checkCommon/properties/roles"},
        "mode": {"enum": ["any", "all"]},
        "priority": {"enum": ["high", "medium", "low"]},
        "minLength": {"type": "integer", "minimum": 1, "maximum": 10000}
      }
    },
    "groupCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "kind", "roles", "priority"],
      "properties": {
        "checkId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,79}$"},
        "kind": {"enum": ["one_of_roles_non_empty", "all_roles_non_empty"]},
        "roles": {"$ref": "#/$defs/checkCommon/properties/roles"},
        "priority": {"enum": ["high", "medium", "low"]}
      }
    },
    "check": {
      "oneOf": [
        {"$ref": "#/$defs/modeCheck"},
        {"$ref": "#/$defs/minLengthCheck"},
        {"$ref": "#/$defs/groupCheck"}
      ]
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileId", "noteTypeId", "noteTypeName", "storedState", "displayName",
        "expectedFingerprint", "appliesTo", "fieldMappings", "checks", "confirmedAt", "updatedAt"
      ],
      "properties": {
        "profileId": {"type": "string", "pattern": "^note-type-[1-9][0-9]{0,18}$", "maxLength": 80},
        "noteTypeId": {"$ref": "#/$defs/decimalId"},
        "noteTypeName": {"type": "string", "minLength": 1, "maxLength": 160},
        "storedState": {"enum": ["suggested", "confirmed", "disabled"]},
        "displayName": {"type": "string", "minLength": 1, "maxLength": 160},
        "expectedFingerprint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": {"const": "sha256"},
            "value": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        },
        "appliesTo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["templateOrdinals"],
          "properties": {
            "templateOrdinals": {
              "type": "array",
              "maxItems": 16,
              "uniqueItems": true,
              "items": {"type": "integer", "minimum": 0, "maximum": 31}
            }
          }
        },
        "fieldMappings": {
          "type": "array",
          "maxItems": 32,
          "items": {"$ref": "#/$defs/fieldMapping"}
        },
        "checks": {
          "type": "array",
          "maxItems": 32,
          "items": {"$ref": "#/$defs/check"}
        },
        "confirmedAt": {"oneOf": [{"$ref": "#/$defs/timestamp"}, {"type": "null"}]},
        "updatedAt": {"$ref": "#/$defs/timestamp"}
      },
      "allOf": [
        {
          "if": {"properties": {"storedState": {"const": "confirmed"}}, "required": ["storedState"]},
          "then": {"properties": {"confirmedAt": {"$ref": "#/$defs/timestamp"}}}
        }
      ]
    }
  }
}
