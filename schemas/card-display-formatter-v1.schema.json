{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anki-study-report.local/schemas/card-display-formatter-v1.schema.json",
  "title": "Anki Study Report card display formatter document v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "revision", "formatters"],
  "properties": {
    "schemaVersion": {"const": 1},
    "revision": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "formatters": {
      "type": "array",
      "maxItems": 1000,
      "items": {"$ref": "#/$defs/formatter"}
    }
  },
  "$defs": {
    "decimalId": {"type": "string", "pattern": "^[1-9][0-9]{0,18}$"},
    "timestamp": {
      "type": "string",
      "maxLength": 40,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "formatter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noteTypeId", "noteTypeName", "templateOrdinal", "templateName",
        "storedState", "inputSource", "textMode", "imageMode", "audioMode",
        "maxLines", "lineSeparator", "maxCharacters", "updatedAt"
      ],
      "properties": {
        "noteTypeId": {"$ref": "#/$defs/decimalId"},
        "noteTypeName": {"type": "string", "minLength": 1, "maxLength": 160},
        "templateOrdinal": {
          "oneOf": [
            {"type": "integer", "minimum": 0, "maximum": 31},
            {"type": "null"}
          ]
        },
        "templateName": {
          "oneOf": [
            {"type": "string", "minLength": 1, "maxLength": 160},
            {"type": "null"}
          ]
        },
        "storedState": {"enum": ["enabled", "disabled"]},
        "inputSource": {"enum": ["browser_question", "reviewer_front"]},
        "textMode": {"enum": ["preserve", "omit"]},
        "imageMode": {"enum": ["omit", "filename", "stem", "marker"]},
        "audioMode": {"enum": ["omit", "filename", "stem", "marker"]},
        "maxLines": {"type": "integer", "minimum": 1, "maximum": 4},
        "lineSeparator": {
          "type": "string",
          "maxLength": 8,
          "pattern": "^[^\\u0000-\\u001F\\u007F]*$"
        },
        "maxCharacters": {"type": "integer", "minimum": 1, "maximum": 240},
        "updatedAt": {"$ref": "#/$defs/timestamp"}
      },
      "allOf": [
        {
          "if": {"properties": {"templateOrdinal": {"type": "null"}}, "required": ["templateOrdinal"]},
          "then": {"properties": {"templateName": {"type": "null"}}},
          "else": {"properties": {"templateName": {"type": "string", "minLength": 1, "maxLength": 160}}}
        }
      ]
    }
  }
}
