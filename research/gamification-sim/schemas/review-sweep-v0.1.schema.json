{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:anki-study-report:review-sweep:v0.1",
  "title": "Bounded review parameter sweep",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sweep_version",
    "sweep_id",
    "corpus_path",
    "max_evaluated_candidates",
    "shortlist_size",
    "epsilon",
    "stages",
    "sensitivity_parameter_set_ids"
  ],
  "properties": {
    "sweep_version": {"const": "review-sweep-v0.1"},
    "sweep_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "corpus_path": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*://)[A-Za-z0-9._/-]+$"
    },
    "max_evaluated_candidates": {"type": "integer", "minimum": 17, "maximum": 64},
    "shortlist_size": {"type": "integer", "minimum": 1, "maximum": 2},
    "epsilon": {"type": "number", "exclusiveMinimum": 0, "maximum": 0.01},
    "stages": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {"$ref": "#/$defs/rewardStage"},
        {"$ref": "#/$defs/volumeStage"},
        {"$ref": "#/$defs/completionStage"},
        {"$ref": "#/$defs/supportStage"},
        {"$ref": "#/$defs/supplementalStage"}
      ],
      "items": false
    },
    "sensitivity_parameter_set_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[RVCSP]-[A-Z0-9-]+(?:\\+[RVCSP]-[A-Z0-9-]+)*$"}
    }
  },
  "$defs": {
    "stageBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "candidate_ids"],
      "properties": {
        "family": {"type": "string"},
        "candidate_ids": {
          "type": "array",
          "minItems": 3,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[RVCSP]-[A-Z0-9-]+$"}
        }
      }
    },
    "rewardStage": {"allOf": [{"$ref": "#/$defs/stageBase"}, {"properties": {"family": {"const": "reward"}}}]},
    "volumeStage": {"allOf": [{"$ref": "#/$defs/stageBase"}, {"properties": {"family": {"const": "volume"}}}]},
    "completionStage": {"allOf": [{"$ref": "#/$defs/stageBase"}, {"properties": {"family": {"const": "completion"}}}]},
    "supportStage": {"allOf": [{"$ref": "#/$defs/stageBase"}, {"properties": {"family": {"const": "support"}}}]},
    "supplementalStage": {"allOf": [{"$ref": "#/$defs/stageBase"}, {"properties": {"family": {"const": "supplemental"}}}]}
  }
}
