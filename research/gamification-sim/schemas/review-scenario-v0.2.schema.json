{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anki-study-report.local/schemas/review-scenario-v0.2.schema.json",
  "title": "Anki Study Report deterministic review scenario v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario_version",
    "scenario_id",
    "title",
    "category",
    "rule_version",
    "days",
    "assertions"
  ],
  "properties": {
    "scenario_version": {
      "const": "review-scenario-v0.2"
    },
    "scenario_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 80
    },
    "title": {
      "$ref": "#/$defs/safeText"
    },
    "category": {
      "enum": [
        "ordinary",
        "edge",
        "control",
        "abuse",
        "regression"
      ]
    },
    "rule_version": {
      "const": "review-v0.1"
    },
    "description": {
      "$ref": "#/$defs/safeText"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "maxLength": 48
      },
      "uniqueItems": true,
      "default": []
    },
    "control_scenario_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "comparison_basis": {
      "enum": [
        "same-core-opportunities",
        "documented-difference"
      ]
    },
    "comparison_note": {
      "$ref": "#/$defs/safeText"
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/day"
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assertion"
      }
    }
  },
  "$defs": {
    "safeText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!.*://)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).*$"
    },
    "ankiDay": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retrievability_actual": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "retrievability_natural_due": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stability_before": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "stability_good_counterfactual": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low",
            "unavailable"
          ]
        }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_event_key",
        "card_lineage",
        "anki_day",
        "outcome"
      ],
      "properties": {
        "source_event_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "card_lineage": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "anki_day": {
          "$ref": "#/$defs/ankiDay"
        },
        "outcome": {
          "enum": [
            "again",
            "hard",
            "good",
            "easy",
            "none"
          ]
        },
        "eligibility_class": {
          "enum": [
            "core",
            "support",
            "supplemental",
            "none",
            "route_to_learn",
            "deferred"
          ]
        },
        "due_relation": {
          "enum": [
            "on_time",
            "overdue",
            "early",
            "forced_due",
            "unknown"
          ]
        },
        "source": {
          "enum": [
            "normal_queue",
            "filtered_rescheduling",
            "filtered_preview",
            "review_ahead",
            "manual_operation",
            "imported_history",
            "custom_scheduler",
            "unknown"
          ]
        },
        "role": {
          "enum": [
            "primary",
            "recovery",
            "supplemental",
            "duplicate",
            "administrative"
          ]
        },
        "memory": {
          "$ref": "#/$defs/memory"
        },
        "core_eligibility": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "bonus_eligibility": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "response_validity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "administrative": {
          "type": "boolean"
        },
        "preview_without_rescheduling": {
          "type": "boolean"
        },
        "forced_due": {
          "type": "boolean"
        },
        "supplemental_units": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "repeatEpisodes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "prefix",
        "template"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "prefix": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "template": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "outcome": {
              "enum": [
                "again",
                "hard",
                "good",
                "easy",
                "none"
              ]
            },
            "eligibility_class": {
              "enum": [
                "core",
                "support",
                "supplemental",
                "none",
                "route_to_learn",
                "deferred"
              ]
            },
            "due_relation": {
              "enum": [
                "on_time",
                "overdue",
                "early",
                "forced_due",
                "unknown"
              ]
            },
            "source": {
              "enum": [
                "normal_queue",
                "filtered_rescheduling",
                "filtered_preview",
                "review_ahead",
                "manual_operation",
                "imported_history",
                "custom_scheduler",
                "unknown"
              ]
            },
            "role": {
              "enum": [
                "primary",
                "recovery",
                "supplemental",
                "duplicate",
                "administrative"
              ]
            },
            "memory": {
              "$ref": "#/$defs/memory"
            },
            "core_eligibility": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            },
            "bonus_eligibility": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "response_validity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "administrative": {
              "type": "boolean"
            },
            "preview_without_rescheduling": {
              "type": "boolean"
            },
            "forced_due": {
              "type": "boolean"
            },
            "supplemental_units": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "episodes"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "maxLength": 80
        },
        "episodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/episode"
          }
        },
        "repeat_episodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repeatEpisodes"
          }
        }
      }
    },
    "supportEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_event_key",
        "parent_episode_key",
        "kind"
      ],
      "properties": {
        "source_event_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "parent_episode_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "kind": {
          "enum": [
            "first_step",
            "second_step",
            "completion",
            "interday_recovery",
            "other"
          ]
        }
      }
    },
    "supplementalEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_event_key",
        "units"
      ],
      "properties": {
        "source_event_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "units": {
          "type": "number",
          "minimum": 0
        },
        "permanent_eligible": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "collection_cleared",
            "scope_cleared",
            "configured_limit_reached",
            "partial",
            "zero_due",
            "snapshot_uncertain"
          ]
        },
        "natural_due_at_start": {
          "type": "integer",
          "minimum": 0
        },
        "due_visible_under_limits": {
          "type": "integer",
          "minimum": 0
        },
        "due_hidden_by_limits": {
          "type": "integer",
          "minimum": 0
        },
        "snapshot_confident": {
          "type": "boolean"
        }
      }
    },
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anki_day",
        "sessions"
      ],
      "properties": {
        "anki_day": {
          "$ref": "#/$defs/ankiDay"
        },
        "workload": {
          "$ref": "#/$defs/workload"
        },
        "sessions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/session"
          }
        },
        "support_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supportEvent"
          }
        },
        "supplemental_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supplementalEvent"
          }
        },
        "undone_source_event_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "rationale",
        "type",
        "scope",
        "metric",
        "expected"
      ],
      "properties": {
        "class": {
          "enum": [
            "invariant",
            "regression"
          ]
        },
        "rationale": {
          "$ref": "#/$defs/safeText"
        },
        "applies_to_parameter_set_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*(?:\\+[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*)*$"
          }
        },
        "type": {
          "enum": [
            "equals",
            "approximately_equals",
            "less_than",
            "less_than_or_equal",
            "greater_than",
            "greater_than_or_equal",
            "equals_control",
            "delta_from_control_lte",
            "delta_from_control_gte",
            "ratio_to_control_lte",
            "ratio_to_control_gte"
          ]
        },
        "scope": {
          "enum": [
            "day",
            "scenario",
            "comparison"
          ]
        },
        "metric": {
          "enum": [
            "core_baseline",
            "core_context",
            "support",
            "supplemental",
            "volume_credit",
            "completion_credit",
            "total_review_units",
            "qualified_volume",
            "unique_core_episodes",
            "successful_core_episodes",
            "failed_core_episodes",
            "bonus_share"
          ]
        },
        "expected": {
          "type": "number"
        },
        "tolerance": {
          "type": "number",
          "minimum": 0
        },
        "anki_day": {
          "$ref": "#/$defs/ankiDay"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "class"
            ],
            "properties": {
              "class": {
                "const": "regression"
              }
            }
          },
          "then": {
            "required": [
              "applies_to_parameter_set_ids"
            ]
          }
        },
        {
          "if": {
            "required": [
              "class"
            ],
            "properties": {
              "class": {
                "const": "invariant"
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "applies_to_parameter_set_ids"
              ]
            }
          }
        }
      ]
    }
  }
}
